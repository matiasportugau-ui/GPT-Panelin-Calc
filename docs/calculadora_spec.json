  "calculo_techo": {
    "descripcion": "Secuencia de calculo del BOM para una seccion de techo.",
    "fase_1_cantidades": {
      "paso_1_dimensiones": {
        "fuente": "PANEL_DEFS en catalog.js (hardcoded, NO del CSV)",
        "variables_producidas": ["panelSku", "panelName", "au_m", "precio_m2"],
        "formulas": {
          "cantP_desde_ancho":   "ceil(ancho_m / au_m)",
          "cantP_desde_paneles": "ceil(cant_paneles)",
          "anchoEfectivo":       "cantP * au_m",
          "areaRaw":             "cantP * au_m * largo_m",
          "area_m2":             "round(areaRaw, 2)"
        }
      },
      "paso_2_gotero": {
        "condicion_habilitante": "familia IN ['ISOROOF_3G','ISOROOF_FOIL','ISOROOF_PLUS','ISODEC_PIR','ISODEC_EPS']",
        "items": [
          {
            "id": "gotero_frontal",
            "condicion": "tiene_gotero",
            "sku_logica": "tipo_gotero_frontal=='greca' AND familia IN ISOROOF_* ? 'GFCGR30' : gotero_skus[familia].frontal[espesor]",
            "formula_cantidad": "ceil(anchoEfectivo / 3.03)",
            "unidad": "pieza"
          },
          {
            "id": "gotero_superior",
            "condicion": "tiene_gotero",
            "sku_logica": "familia=='ISODEC_EPS' ? '6828' : gotero_skus[familia].superior[espesor]",
            "formula_cantidad_isoroof_pir": "ceil(anchoEfectivo / 3.03)",
            "formula_cantidad_eps":         "ceil(anchoEfectivo / 3.00)",
            "unidad": "pieza"
          },
          {
            "id": "gotero_lateral",
            "condicion": "tiene_gotero",
            "sku_logica": "gotero_skus[familia].lateral[espesor]",
            "formula_cantidad": "ceil(largo_m / 3.00) * 2",
            "unidad": "pieza"
          },
          {
            "id": "cumbrera",
            "condicion": "tiene_gotero AND tiene_cumbrera==true",
            "sku_logica": "gotero_skus[familia].cumbrera",
            "formula_cantidad": "ceil(anchoEfectivo / 3.00)",
            "unidad": "pieza"
          },
          {
            "id": "canalon",
            "condicion": "tiene_gotero AND tiene_canalon==true AND gotero_skus[familia].canalon[espesor] != null",
            "sku_logica": "gotero_skus[familia].canalon[espesor]",
            "formula_cantidad": "ceil(anchoEfectivo / 3.03)",
            "unidad": "pieza"
          },
          {
            "id": "soporte_canalon",
            "condicion": "misma_que_canalon",
            "sku_logica": "gotero_skus[familia].soporte_canalon",
            "formula_cantidad": "ceil(anchoEfectivo / 1.50)",
            "unidad": "pieza"
          }
        ]
      },
      "paso_3_fijacion": {
        "sist": "SIST_FIJACION_TECHO[familia]",
        "ver_nodo": "sistemas_fijacion"
      },
      "paso_4_selladores": {
        "items": [
          {
            "id": "cinta_butilo",
            "sku": "C.But.",
            "formula": "max(1, ceil((cantP - 1) * largo_m / 22.5))",
            "unidad": "rollo",
            "condicion": "siempre"
          },
          {
            "id": "silicona",
            "sku": "Bromplast",
            "formula": "ceil(cantP * 0.5)",
            "unidad": "cartucho",
            "condicion": "siempre"
          }
        ]
      }
    },
    "fase_2_precios": {
      "panel": "precio_m2 (de getPanelInfo) * areaRaw",
      "accesorios": "getAccessoryInfo(sku, lista_precios).precio * cantidad"
    },
    "output": {
      "tipo": "techo",
      "campos_geometricos": ["familia","espesor_mm","ancho_m","largo_m","area_m2","cant_paneles","sist_fijacion"],
      "items": "array de {sku, descripcion, cantidad, unidad, precio_unit, subtotal}",
      "subtotal": "suma de todos los subtotales de items"
    }
  },

  "calculo_pared": {
    "descripcion": "Secuencia de calculo del BOM para una seccion de pared o fachada.",
    "fase_1_cantidades": {
      "paso_1_dimensiones": {
        "fuente": "PANEL_DEFS (mismo que techo)",
        "formulas": {
          "cantP":           "ceil(ancho_m / au_m) o ceil(cant_paneles)",
          "anchoEfectivo":   "cantP * au_m",
          "areaBruta":       "round(cantP * au_m * largo_m, 2)",
          "areaAberturas":   "sum(ab.ancho * ab.alto * ab.cant) para cada abertura",
          "areaNeta":        "max(0, areaBruta - areaAberturas)"
        }
      },
      "paso_2_panel_y_perfiles": {
        "items": [
          {
            "id": "panel",
            "formula_costo": "areaNeta * precio_m2",
            "nota": "En pared se cobra area NETA, no bruta"
          },
          {
            "id": "perfil_u",
            "condicion": "PERFIL_U_SKU[espesor] != null",
            "sku_logica": "PERFIL_U_SKU[espesor]: 40-60→PU50MM, 80-100→PU100MM, 150→PU150MM, 200→PU200MM, 250→PU250MM",
            "formulas": {
              "mlPerfilU": "2 * anchoEfectivo",
              "cantPU":    "ceil(mlPerfilU / 3.0)"
            },
            "unidad": "pieza"
          },
          {
            "id": "perfil_k2",
            "condicion": "incl_k2==true AND cantP > 1",
            "sku": "K2",
            "formula": "( cantP - 1 ) * ceil(largo_m / 3.0)",
            "unidad": "pieza"
          },
          {
            "id": "esquinero_ext",
            "condicion": "num_esq_ext > 0",
            "sku": "ESQ-EXT",
            "formula": "num_esq_ext * ceil(largo_m / 3.0)",
            "unidad": "pieza"
          },
          {
            "id": "esquinero_int",
            "condicion": "num_esq_int > 0",
            "sku": "ESQ-INT",
            "formula": "num_esq_int * ceil(largo_m / 3.0)",
            "unidad": "pieza"
          },
          {
            "id": "angulo_5852",
            "condicion": "incl_5852==true",
            "sku": "PLECHU98",
            "formula": "ceil(anchoEfectivo / 6.8)",
            "unidad": "pieza"
          }
        ]
      },
      "paso_3_fijaciones": {
        "items": [
          {
            "id": "tmome_aratrap",
            "condicion": "estructura IN ['metal','mixto']",
            "formula": "ceil(areaNeta * 5.5)",
            "skus": ["TMOME","ARATRAP"],
            "unidad": "und"
          },
          {
            "id": "anclaje_h",
            "condicion": "siempre",
            "sku": "ANCLAJE_H",
            "formula": "ceil(anchoEfectivo / 0.30)",
            "unidad": "unid"
          },
          {
            "id": "remaches_rpop",
            "condicion": "siempre",
            "sku": "RPOP",
            "formulas": {
              "cantRemaches":    "cantP * 2",
              "cantCajasRPOP":   "max(1, ceil(cantRemaches / 1000))"
            },
            "unidad": "caja"
          }
        ]
      },
      "paso_4_selladores": {
        "items": [
          {
            "id": "cinta_butilo",
            "sku": "C.But.",
            "formula": "max(1, ceil((cantP - 1) * largo_m / 22.5))",
            "unidad": "rollo"
          },
          {
            "id": "silicona",
            "sku": "Bromplast",
            "formulas": {
              "mlJuntas":    "(cantP - 1) * largo_m + anchoEfectivo * 2",
              "cantSilicona": "ceil(mlJuntas / 8)"
            },
            "unidad": "cartucho",
            "nota": "Formula por ML de junta — mas precisa que la de techo"
          }
        ]
      }
    },
    "output": {
      "tipo": "pared | pared_frontal_posterior | pared_lateral",
      "campos_geometricos": ["familia","espesor_mm","ancho_m","largo_m","area_bruta_m2","area_aberturas_m2","area_neta_m2","cant_paneles"],
      "items": "array de {sku, descripcion, cantidad, unidad, precio_unit, subtotal}",
      "subtotal": "suma de todos los subtotales de items"
    }
  },

