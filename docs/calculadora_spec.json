  "sistemas_fijacion": {
    "varilla_tuerca": {
      "familias": ["ISODEC_EPS", "ISODEC_PIR"],
      "params": {
        "laterales_por_punto": 2,
        "intervalo_largo_m": 2.5,
        "varillas_por_punto": 0.25,
        "apoyos_minimos_default": 2
      },
      "formulas": {
        "apoyosReales": "apoyos > 0 ? apoyos : apoyos_minimos_default",
        "ptosFij": "ceil(cantP * apoyosReales * laterales_por_punto + largo_m * 2 / intervalo_largo_m)",
        "cantVarillas": "ceil(ptosFij * varillas_por_punto)",
        "cantTuercas": "cantVarillas * 2",
        "cantArcCarr": "cantVarillas * 2",
        "cantArPP": "cantVarillas * 2",
        "cantTacos": "ptosFij — SOLO si estructura = 'hormigon'"
      },
      "items": [
        { "sku": "VARILLA38",  "formula": "cantVarillas", "unidad": "unid",  "condicion": "siempre" },
        { "sku": "TUERCA38",   "formula": "cantTuercas",  "unidad": "unid",  "condicion": "siempre" },
        { "sku": "ARCA38",     "formula": "cantArcCarr",  "unidad": "unid",  "condicion": "siempre" },
        { "sku": "ARAPP",      "formula": "cantArPP",     "unidad": "unid",  "condicion": "siempre" },
        { "sku": "TACEXP38",   "formula": "ptosFij",      "unidad": "unid",  "condicion": "estructura == 'hormigon'" }
      ]
    },
    "caballete_tornillo": {
      "familias": ["ISOROOF_3G", "ISOROOF_FOIL", "ISOROOF_PLUS"],
      "params": {
        "tramos_por_panel": 3,
        "paso_apoyo_m": 2.9,
        "intervalo_perimetro_m": 0.30
      },
      "formulas": {
        "cantCaballetes": "ceil(cantP * 3 * (largo_m / 2.9 + 1) + largo_m * 2 / 0.30)",
        "cajasAgujas": "ceil(cantCaballetes * 2 / 100)"
      },
      "items": [
        { "sku": "CABALLETE",  "formula": "cantCaballetes", "unidad": "unid",  "condicion": "siempre" },
        { "sku": "TORN_AGUJA", "formula": "cajasAgujas",    "unidad": "caja",  "condicion": "siempre" }
      ]
    },
    "tmome": {
      "familias": ["ISOPANEL_EPS", "ISOWALL_PIR", "ISOFRIG_PIR"],
      "params_techo": { "tornillos_por_m2": 6 },
      "params_pared": { "tornillos_por_m2": 5.5 },
      "formulas_techo": {
        "cantTornillos": "ceil(areaRaw * 6)"
      },
      "formulas_pared": {
        "cantTornillos": "ceil(areaNeta * 5.5)",
        "condicion": "estructura == 'metal' OR estructura == 'mixto'"
      },
      "items": [
        { "sku": "TMOME",   "formula": "cantTornillos", "unidad": "und" },
        { "sku": "ARATRAP", "formula": "cantTornillos", "unidad": "und" }
      ]
    }
  },

