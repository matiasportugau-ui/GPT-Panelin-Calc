  "validaciones": [
    {
      "id": "escenario_valido",
      "tipo": "fatal",
      "condicion": "escenario NOT IN escenarios_validos",
      "mensaje": "Escenario invalido"
    },
    {
      "id": "ancho_o_paneles",
      "tipo": "fatal",
      "condicion": "ancho_m == null AND cant_paneles == null",
      "mensaje": "Se requiere ancho_m o cant_paneles"
    },
    {
      "id": "no_ambos_anchos",
      "tipo": "fatal",
      "condicion": "ancho_m != null AND cant_paneles != null",
      "mensaje": "No se pueden enviar simultaneamente ancho_m y cant_paneles"
    },
    {
      "id": "largo_positivo",
      "tipo": "fatal",
      "condicion": "largo_m <= 0 OR NOT isFinite(largo_m)"
    },
    {
      "id": "largo_min",
      "tipo": "warning",
      "condicion": "largo_m < panel_largos[familia].min",
      "mensaje": "largo por debajo del minimo para la familia"
    },
    {
      "id": "largo_max",
      "tipo": "warning",
      "condicion": "largo_m > panel_largos[familia].max",
      "mensaje": "largo supera el maximo para la familia"
    },
    {
      "id": "color_disponible",
      "tipo": "warning",
      "condicion": "color != null AND color NOT IN colores[familia]"
    },
    {
      "id": "color_espesor",
      "tipo": "warning",
      "condicion": "colores[familia][color].colMax_mm != null AND espesor_mm > colMax_mm"
    },
    {
      "id": "autoportancia",
      "tipo": "warning",
      "condicion": "luz_real > LUCES_MAXIMAS[familia][espesor_mm]",
      "formula_luz": "apoyos > 0 ? largo_m / (apoyos + 1) : largo_m"
    }
  ],

