{
  "_meta": {
    "sistema": "Calculadora Panelin BMC Uruguay",
    "version": "5.1.0",
    "fecha": "2026-03-05",
    "moneda": "USD",
    "iva_rate": 0.22,
    "proposito": "Especificacion estructurada completa del sistema de calculo. Usable para validacion de inputs, generacion de casos de prueba, analisis de combinaciones validas y auditoria de formulas.",
    "formato": "JSON Calculation Flow Specification (CFS). Cada nodo define: tipo, valores validos, dependencias, formulas y condiciones."
  },

  "parametros_entrada": {
    "escenario": {
      "tipo": "enum",
      "requerido": true,
      "valores": ["solo_techo", "solo_fachada", "techo_fachada", "camara_frigorifica"],
      "descripcion": "Define cuantas secciones se calculan y como se arman.",
      "secciones_generadas": {
        "solo_techo":          ["techo"],
        "solo_fachada":        ["pared"],
        "techo_fachada":       ["techo", "pared"],
        "camara_frigorifica":  ["techo", "pared_frontal_posterior", "pared_lateral"]
      }
    },
    "familia": {
      "tipo": "enum",
      "requerido": true,
      "valores": ["ISOROOF_3G","ISOROOF_FOIL","ISOROOF_PLUS","ISODEC_PIR","ISODEC_EPS","ISOPANEL_EPS","ISOWALL_PIR","ISOFRIG_PIR"]
    },
    "espesor_mm": {
      "tipo": "integer",
      "requerido": true,
      "descripcion": "Debe ser un valor valido para la familia seleccionada. Ver tabla familias."
    },
    "ancho_m": {
      "tipo": "float",
      "requerido": "alternativo_a:cant_paneles",
      "restriccion": "mayor_que_0",
      "descripcion": "Ancho del techo o pared. El sistema calcula cantP = ceil(ancho_m / au_m)."
    },
    "cant_paneles": {
      "tipo": "float",
      "requerido": "alternativo_a:ancho_m",
      "restriccion": "mayor_que_0",
      "descripcion": "Cantidad exacta de paneles. cantP = ceil(cant_paneles)."
    },
    "largo_m": {
      "tipo": "float",
      "requerido": true,
      "restriccion": "mayor_que_0",
      "descripcion": "Largo del techo o altura de la pared. Afecta validacion lmin/lmax y autoportancia."
    },
    "lista_precios": {
      "tipo": "enum",
      "requerido": false,
      "default": "venta",
      "valores": ["venta", "web"],
      "descripcion": "Selecciona columna de precio en el catalogo para todos los items."
    },
    "apoyos": {
      "tipo": "integer",
      "requerido": false,
      "default": 0,
      "restriccion": "mayor_o_igual_0",
      "descripcion": "Apoyos intermedios. Con apoyos > 0: luz_real = largo_m / (apoyos + 1). Afecta fijacion varilla_tuerca."
    },
    "estructura": {
      "tipo": "enum",
      "requerido": false,
      "default": "metal",
      "valores": ["metal", "hormigon", "mixto"],
      "descripcion": "En techo varilla_tuerca: hormigon agrega tacos expansivos. En pared: metal/mixto incluye TMOME+ARATRAP."
    },
    "tiene_cumbrera": {
      "tipo": "boolean",
      "requerido": false,
      "default": false,
      "aplica_a": "techo",
      "descripcion": "Si true: agrega accesorio de cumbrera. Solo para familias con sistema de gotero."
    },
    "tiene_canalon": {
      "tipo": "boolean",
      "requerido": false,
      "default": false,
      "aplica_a": "techo",
      "descripcion": "Si true: agrega canalon y soporte. Solo para familias con sistema de gotero y SKU de canalon definido."
    },
    "tipo_gotero_frontal": {
      "tipo": "enum",
      "requerido": false,
      "default": "liso",
      "valores": ["liso", "greca"],
      "aplica_a": "techo",
      "descripcion": "Solo para ISOROOF_3G/FOIL/PLUS. greca usa SKU universal GFCGR30."
    },
    "color": {
      "tipo": "string",
      "requerido": false,
      "descripcion": "Solo para validacion y warnings. No afecta calculo. Ver tabla colores."
    },
    "envio_usd": {
      "tipo": "float",
      "requerido": false,
      "descripcion": "Si se provee, se incluye como campo separado en la cotizacion. No afecta materiales ni IVA."
    },
    "aberturas": {
      "tipo": "array",
      "item_schema": { "ancho": "float", "alto": "float", "cant": "integer" },
      "requerido": false,
      "default": [],
      "aplica_a": "pared",
      "descripcion": "Area total descontada = sum(ancho * alto * cant). Afecta areaNeta y costo_paneles en pared."
    },
    "num_esq_ext": {
      "tipo": "integer",
      "requerido": false,
      "default": 0,
      "aplica_a": "pared",
      "descripcion": "Cantidad de esquinas exteriores. Genera items ESQ-EXT."
    },
    "num_esq_int": {
      "tipo": "integer",
      "requerido": false,
      "default": 0,
      "aplica_a": "pared",
      "descripcion": "Cantidad de esquinas interiores. Genera items ESQ-INT."
    },
    "incl_k2": {
      "tipo": "boolean",
      "requerido": false,
      "default": true,
      "aplica_a": "pared",
      "descripcion": "Si true Y cantP > 1: incluye perfiles K2 de junta vertical."
    },
    "incl_5852": {
      "tipo": "boolean",
      "requerido": false,
      "default": false,
      "aplica_a": "pared",
      "descripcion": "Si true: incluye angulo aluminio 5852 (piezas de 6.8m)."
    }
  },

