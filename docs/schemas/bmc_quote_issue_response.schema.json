{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bmcuruguay.com/schemas/bmc_quote_issue_response.schema.json",
  "title": "BMC Quote Issue Response",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "quote_id",
    "quote_ref",
    "version",
    "estado_cotizacion",
    "subtotal",
    "iva_22",
    "total",
    "links",
    "timestamps"
  ],
  "properties": {
    "quote_id": {
      "type": "string",
      "minLength": 3
    },
    "quote_ref": {
      "type": "string",
      "pattern": "^BMC-COT-(20[0-9]{2})-([0-9]{4})$"
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "estado_cotizacion": {
      "type": "string",
      "enum": [
        "EMITIDA",
        "ENVIADA",
        "EN_SEGUIMIENTO",
        "APROBADA",
        "RECHAZADA",
        "VENCIDA",
        "AJUSTANDO"
      ]
    },
    "subtotal": {
      "type": "number",
      "minimum": 0
    },
    "iva_22": {
      "type": "number",
      "minimum": 0
    },
    "total": {
      "type": "number",
      "minimum": 0
    },
    "links": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "editable_url",
        "pdf_url",
        "folder_url"
      ],
      "properties": {
        "editable_url": {
          "type": "string",
          "format": "uri"
        },
        "pdf_url": {
          "type": "string",
          "format": "uri"
        },
        "folder_url": {
          "type": "string",
          "format": "uri"
        },
        "payload_url": {
          "type": "string",
          "format": "uri"
        }
      }
    },
    "timestamps": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "issued_at",
        "updated_at"
      ],
      "properties": {
        "issued_at": {
          "type": "string",
          "format": "date-time"
        },
        "updated_at": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "checks": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "pdf_immutable": {
          "type": "boolean",
          "const": true
        }
      }
    },
    "error": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "error_code": {
          "type": "string"
        },
        "message": {
          "type": "string"
        },
        "trace_id": {
          "type": "string"
        }
      }
    }
  }
}
