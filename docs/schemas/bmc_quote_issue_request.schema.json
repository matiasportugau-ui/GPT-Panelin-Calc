{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://bmcuruguay.com/schemas/bmc_quote_issue_request.schema.json",
  "title": "BMC Quote Issue Request",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "client",
    "calculation_result",
    "status_target",
    "issued_by"
  ],
  "properties": {
    "quote_ref": {
      "type": "string",
      "pattern": "^BMC-COT-(20[0-9]{2})-([0-9]{4})$"
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "status_target": {
      "type": "string",
      "enum": [
        "EMITIDA",
        "ENVIADA"
      ]
    },
    "issued_by": {
      "type": "string",
      "minLength": 2
    },
    "client": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "nombre"
      ],
      "properties": {
        "client_id": {
          "type": "string"
        },
        "nombre": {
          "type": "string",
          "minLength": 2
        },
        "telefono": {
          "type": "string"
        }
      }
    },
    "interaction": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "interaction_id": {
          "type": "string"
        },
        "canal": {
          "type": "string"
        },
        "responsable": {
          "type": "string"
        }
      }
    },
    "calculation_result": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "subtotal",
        "iva_22",
        "total",
        "lineas"
      ],
      "properties": {
        "subtotal": {
          "type": "number",
          "minimum": 0
        },
        "iva_22": {
          "type": "number",
          "minimum": 0
        },
        "total": {
          "type": "number",
          "minimum": 0
        },
        "warnings": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "lineas": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "tipo",
              "descripcion",
              "cantidad",
              "importe"
            ],
            "properties": {
              "tipo": {
                "type": "string",
                "enum": [
                  "producto",
                  "accesorio",
                  "fijacion"
                ]
              },
              "sku": {
                "type": "string"
              },
              "descripcion": {
                "type": "string"
              },
              "cantidad": {
                "type": "number",
                "exclusiveMinimum": 0
              },
              "unidad": {
                "type": "string"
              },
              "precio_unitario": {
                "type": "number",
                "minimum": 0
              },
              "importe": {
                "type": "number",
                "minimum": 0
              }
            }
          }
        }
      }
    },
    "tracker_context": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "sheet_id": {
          "type": "string"
        },
        "row_number": {
          "type": "integer",
          "minimum": 1
        }
      }
    }
  }
}
